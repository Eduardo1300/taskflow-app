# ============================================
# DESARROLLO LOCAL (con Supabase local o Docker)
# ============================================
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskflow

# ============================================
# PRODUCCIÓN (Supabase Cloud)
# ============================================
# Reemplaza con tu URL de Supabase (Settings > Database > Connection string)
DATABASE_URL=postgresql://postgres.[TU-PROJECT-REF]:[TU-PASSWORD]@db.[TU-PROJECT-REF].supabase.co:5432/postgres

# ============================================
# JWT Secret (不变)
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
PORT=3000
